{
  "name": "deepseek-native-chat",
  "displayName": "DeepSeek Native Chat",
  "description": "DeepSeek AI as a native language model provider in VS Code",
  "version": "0.1.0",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "enabledApiProposals": [
    "languageModelSystem"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseek.configure",
        "title": "Configure DeepSeek API Key",
        "category": "DeepSeek"
      }
    ],
    "configuration": {
      "title": "DeepSeek",
      "properties": {
        "deepseek.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your DeepSeek API key (get from https://platform.deepseek.com)",
          "scope": "application"
        },
        "deepseek.baseURL": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "install:dev": "npm install && npm run compile",
    "package": "vsce package --allow-missing-repository",
    "install:local": "npm run package && code --install-extension deepseek-native-chat-*.vsix || echo \"If code command not found, install manually from VS Code: Extensions → ... → Install from VSIX\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.26.1"
  },
  "dependencies": {
    "node-fetch": "^2.6.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/deepseek-native-chat.git"
  }
}
